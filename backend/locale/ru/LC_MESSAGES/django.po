msgid "Подтвердите почту в Tambur"
msgstr "Подтвердите почту в Tambur"

msgid "Здравствуйте, %(username)s!\n\nЧтобы завершить подтверждение почты, откройте секретную ссылку:\n%(verification_url)s\n\nСсылка секретная и привязана к вашему аккаунту.\nЕсли это были не вы, просто проигнорируйте это письмо."
msgstr "Здравствуйте, %(username)s!\n\nЧтобы завершить подтверждение почты, откройте секретную ссылку:\n%(verification_url)s\n\nСсылка секретная и привязана к вашему аккаунту.\nЕсли это были не вы, просто проигнорируйте это письмо."

msgid "<p>Здравствуйте, %(username)s!</p>"
msgstr "<p>Здравствуйте, %(username)s!</p>"

msgid "<p>Чтобы завершить подтверждение почты, откройте секретную ссылку:</p>"
msgstr "<p>Чтобы завершить подтверждение почты, откройте секретную ссылку:</p>"

msgid "Подтвердить почту"
msgstr "Подтвердить почту"

msgid "<p>Ссылка секретная и привязана к вашему аккаунту.</p>"
msgstr "<p>Ссылка секретная и привязана к вашему аккаунту.</p>"

msgid "<p>Если это были не вы, просто проигнорируйте это письмо.</p>"
msgstr "<p>Если это были не вы, просто проигнорируйте это письмо.</p>"

msgid "Ссылка подтверждения недействительна или устарела."
msgstr "Ссылка подтверждения недействительна или устарела."

msgid "У аккаунта не указан email."
msgstr "У аккаунта не указан email."

msgid "Восстановление доступа к Tambur"
msgstr "Восстановление доступа к Tambur"

msgid "Здравствуйте, %(username)s!\n\nМы получили запрос на восстановление доступа к аккаунту.\nЧтобы задать новый пароль, откройте ссылку: %(reset_url)s\n\nЕсли вы не запрашивали восстановление, просто проигнорируйте это письмо."
msgstr "Здравствуйте, %(username)s!\n\nМы получили запрос на восстановление доступа к аккаунту.\nЧтобы задать новый пароль, откройте ссылку: %(reset_url)s\n\nЕсли вы не запрашивали восстановление, просто проигнорируйте это письмо."

msgid "<p>Мы получили запрос на восстановление доступа к аккаунту.</p>"
msgstr "<p>Мы получили запрос на восстановление доступа к аккаунту.</p>"

msgid "Задать новый пароль"
msgstr "Задать новый пароль"

msgid "<p>Если вы не запрашивали восстановление, просто проигнорируйте это письмо.</p>"
msgstr "<p>Если вы не запрашивали восстановление, просто проигнорируйте это письмо.</p>"

msgid "Введите корректный email."
msgstr "Введите корректный email."

msgid "Регистрация по почте отключена. Используйте Telegram."
msgstr "Регистрация по почте отключена. Используйте Telegram."

msgid "Укажите имя пользователя, email и пароль."
msgstr "Укажите имя пользователя, email и пароль."

msgid "Пароль слишком короткий."
msgstr "Пароль слишком короткий."

msgid "Пользователь с таким email уже существует."
msgstr "Пользователь с таким email уже существует."

msgid "Аккаунт с таким email уже существует. Восстановите пароль через подтверждение почты."
msgstr "Аккаунт с таким email уже существует. Восстановите пароль через подтверждение почты."

msgid "Пользователь с таким именем уже существует."
msgstr "Пользователь с таким именем уже существует."

msgid "Ссылка восстановления недействительна или устарела."
msgstr "Ссылка восстановления недействительна или устарела."

msgid "Введите email или имя пользователя и пароль."
msgstr "Введите email или имя пользователя и пароль."

msgid "К этому профилю уже привязан другой VK."
msgstr "К этому профилю уже привязан другой VK."

